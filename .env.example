ENABLE_PROXY=true
PROXY_URL=http://zproxy.lum-superproxy.io:22225/
PROXY_AUTH=username:password
# Optional: rotate credentials by comma-separated list
PROXY_AUTH_LIST=username1:password1,username2:password2

# Supabase (required for upsert)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional runtime controls
SPIDERS=
SCRAPY_LOG_LEVEL=INFO
SCRAPY_RETRY_TIMES=5
SCRAPY_DOWNLOAD_TIMEOUT=45
SPIDER_TIMEOUT_SECONDS=1800
