ENABLE_PROXY=true
PROXY_URL=http://zproxy.lum-superproxy.io:22225/
PROXY_AUTH=username:password
# Optional: rotate credentials by comma-separated list
PROXY_AUTH_LIST=username1:password1,username2:password2

# Supabase (Scrapy pipelines / rocmob_cfg)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Hoot CSV import (Hootprocess/hoot_import.py) — preferred; Secret sb_secret_... or legacy service_role JWT
# If unset, the Hoot job falls back to SUPABASE_SERVICE_ROLE_KEY above.
HOOT_SUPABASE_SECRET_KEY=
# Optional: YYYY-MM-DD for Hootprocess/hoot_inventorydata.py (default: today)
# HOOT_TRANSFER_DATE=sb_secret_**************

# Optional runtime controls
SPIDERS=
SCRAPY_LOG_LEVEL=INFO
SCRAPY_RETRY_TIMES=5
SCRAPY_DOWNLOAD_TIMEOUT=45
SPIDER_TIMEOUT_SECONDS=1800
